# Pins local AWS CLI/Terraform to the Dream Catcher account so a stray `default`
# profile can't target the wrong account. direnv auto-loads this on `cd`; run
# `direnv allow` once. (No direnv? Just prefix commands with AWS_PROFILE=dreamcatcher.)
# CI does NOT use this — it assumes the deploy role via OIDC.
export AWS_PROFILE=dreamcatcher
